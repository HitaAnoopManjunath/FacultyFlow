<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/apple_background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/apple_background"
        app:elevation="0dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:paddingStart="8dp"
            android:paddingEnd="16dp">

            <ImageButton
                android:id="@+id/ivBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_centerVertical="true"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:background="?selectableItemBackgroundBorderless"
                app:tint="@color/ios_blue" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="Timetable"
                android:fontFamily="sans-serif-medium"
                android:textSize="17sp"
                android:textColor="@color/apple_label" />
        </RelativeLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Upload Schedule"
                style="@style/TextAppearance.App.TitleLarge"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Scan your weekly timetable to automatically sync your availability for student bookings."
                style="@style/TextAppearance.App.BodyMedium"
                android:layout_marginBottom="32dp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/uploadArea"
                style="@style/AppleCard"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                app:cardElevation="0dp"
                app:strokeWidth="2dp"
                app:strokeColor="@color/ios_gray6"
                app:cardBackgroundColor="@color/apple_card"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:src="@android:drawable/ic_menu_upload"
                        app:tint="@color/ios_blue"
                        android:layout_marginBottom="16dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Select Document"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="@color/apple_label"
                        android:textSize="17sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="PDF or Image (Max 10MB)"
                        android:textColor="@color/apple_tertiary_label"
                        android:textSize="14sp"
                        android:layout_marginTop="4dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/cameraOption"
                style="@style/AppleButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="20dp"
                android:text="Scan with Camera"
                android:textColor="@color/apple_label"
                app:icon="@android:drawable/ic_menu_camera"
                app:iconTint="@color/apple_label"
                app:backgroundTint="@color/apple_card"
                app:strokeColor="@color/ios_gray6"
                app:strokeWidth="1dp" />

            <!-- Progress -->
            <LinearLayout
                android:id="@+id/progressArea"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone"
                android:layout_marginTop="32dp">

                <com.google.android.material.progressindicator.LinearProgressIndicator
                    android:id="@+id/progressIndicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:trackCornerRadius="4dp"
                    app:trackThickness="8dp"
                    app:indicatorColor="@color/ios_blue" />

                <TextView
                    android:id="@+id/tvProgressText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Analyzing document..."
                    android:textColor="@color/apple_secondary_label"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

            <!-- Success -->
            <LinearLayout
                android:id="@+id/successState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginTop="32dp">

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:src="@android:drawable/ic_menu_save"
                    app:tint="@color/ios_green" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Upload Complete"
                    android:fontFamily="sans-serif-bold"
                    android:textColor="@color/apple_label"
                    android:textSize="18sp"
                    android:layout_marginTop="12dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
